% --- Slide 6 ---
\begin{frame}{Metode Penelitian}
  \begin{columns}[T]
    \begin{column}{0.48\textwidth}
      \footnotesize
      \textbf{Pendekatan}: Kuantitatif Komparatif \par \vspace{0.1cm}
      \textbf{Paradigma}: Research and Development (R\&D) \par \vspace{0.1cm}
      \textbf{Objek}: Output MIDI dari 3 model AI di 4 kondisi instruksi \par \vspace{0.1cm}
      \textbf{Objek Formal}: Kepatuhan harmoni fungsional menurut teori Strube \par \vspace{0.1cm}
      \textbf{Instrumen}: \texttt{strube\_evaluator.py} \par (Python + music21 9.3.0)
    \end{column}
    \begin{column}{0.48\textwidth}
      \footnotesize
      \textbf{\textcolor{SlateBlue}{Dua Fase R\&D:}} \par \vspace{0.1cm}

      \textbf{FASE 1: Bangun \& Validasi Instrumen}
      \begin{itemize}
        \item Kembangkan \texttt{strube\_evaluator.py}
        \item Uji face validity (positif + negatif)
        \item Instrumen dinyatakan valid sebelum generasi dimulai
      \end{itemize}

      \vspace{0.05cm}

      \textbf{FASE 2: Terapkan \& Bandingkan}
      \begin{itemize}
        \item Generate 120 sampel MIDI
        \item Evaluasi otomatis seluruh sampel
        \item Analisis deskriptif komparatif lintas model dan kondisi
      \end{itemize}
    \end{column}
  \end{columns}
\end{frame}

% --- Slide 7 ---
\begin{frame}{Desain Eksperimen: 4 Kondisi}
  \renewcommand{\arraystretch}{1.2}
  \begin{tabularx}{\textwidth}{l l X}
    \textbf{Kondisi} & \textbf{Label} & \textbf{Deskripsi} \\
    \hline
    A & Netral & Tanpa batasan, model bebas sepenuhnya \\
    B & Kunci & Konteks kunci dan periode Barat diberikan \\
    C & SATB Parsial & Soprano ditetapkan, model mengisi A, T, B \\
    \rowcolor{GoldAmber!30}
    \textbf{\textcolor{DarkText}{D}} & \textbf{\textcolor{DarkText}{SATB Penuh}} & \textbf{\textcolor{DarkText}{Soprano + Bass ditetapkan, model mengisi A, T}} \\
    \hline
  \end{tabularx}

  \vspace{0.3cm}
  {\footnotesize \color{gray}\textbf{Catatan metodologis:} \par
  Setiap kondisi menerapkan equivalent conditioning level, bukan prompt string yang identik. \par
  DeepBach dikontrol lewat tensor, Coconet lewat seed nada, NotaGen lewat metadata teks, sesuai antarmuka native masing-masing. (Hadjeres et al., 2017; Huang et al., 2017)}
\end{frame}

