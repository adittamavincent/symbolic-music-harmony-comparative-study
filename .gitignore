# Ignore everything by default
*

# Allow directories to be scanned
!*/

# Do not ignore these specific files
!.gitignore
!*.tex
!*.md
!*.cls
!*.bib
!*.py
!*.json
!Makefile
!.env.example

# Ignore sensitive and environment files
.env
.env.local

# Ignore experimental data, raw data, and outputs
outputs/
data/raw/
scratch/

# Ignore third-party models
models/

# Ignore generated LaTeX entrypoint
thesis/main.tex

# Ignore LaTeX build artifacts
*.aux
*.log
*.out
*.toc
*.fls
*.fdb_latexmk
*.synctex.gz
